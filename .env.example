# .env
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carelink
DB_USER=postgres
DB_PASSWORD=securepassword123

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
REDIS_MAX_CONNECTIONS=100

# Authentication
JWT_SECRET=your_super_secure_jwt_secret_key_12345
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key_67890
JWT_REFRESH_EXPIRES_IN=30d

# Application
APP_NAME=CareLink QR
APP_VERSION=1.0.0
APP_ENV=development

# API Settings
API_RATE_LIMIT=1000
API_TIMEOUT=30000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# File Upload
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=10MB
FILE_TYPES=pdf,jpg,png,audio,video

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=carelink@example.com
SMTP_PASSWORD=email_password_123
SMTP_FROM_ADDRESS=carelink-noreply@example.com

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NEXT_PUBLIC_MOBILE_URL=carelink://

# Mobile Configuration
MOBILE_API_URL=http://localhost:3000/api/v1
MOBILE_PUSH_NOTIFICATIONS=true
MOBILE_CACHE_ENABLED=true

# Third-party Services
FIREBASE_PROJECT_ID=carelink-firebase
FIREBASE_CLIENT_EMAIL=firebase-service-account@carelink.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=your_firebase_private_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Monitoring and Analytics
SENTRY_DSN=https://your_sentry_dsn@sentry.io/123456
ANALYTICS_TRACKING_ID=UA-123456-1
LOG_LEVEL=debug

# Feature Flags
FEATURE_FLAG_EMAIL_NOTIFICATIONS=true
FEATURE_FLAG_REAL_TIME_UPDATES=true
FEATURE_FLAG_OFFLINE_MODE=true
FEATURE_FLAG_ADVANCED_ANALYTICS=true

# QR Code Configuration
QR_CODE_ENABLED=true
QR_CODE_EXPIRATION_DAYS=30
QR_CODE_ACCESS_LEVEL=3

# Notification Settings
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=true
NOTIFICATION_PUSH_ENABLED=true
NOTIFICATION_CHANNEL_PREFERRED=mobile_app

# Security Settings
SECURITY_ENCRYPTION_KEY=encryption_key_12345
SECURITY_TOKEN_VALIDATION=true
SECURITY_ROLE_BASED_ACCESS=true
SECURITY_SESSION_TIMEOUT=30