{
  "name": "carelink-qr",
  "version": "1.0.0",
  "description": "CareLink QR: Real-Time Patient Transparency System for DevKada Hackathon",
  "private": true,
  "homepage": "https://github.com/H4D3ZS/carelink",
  "keywords": [
    "healthcare",
    "patient-care",
    "qr-code",
    "flutter",
    "react",
    "mobile",
    "real-time",
    "devkada-hackathon"
  ],
  "authors": "CareLink QR Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/H4D3ZS/carelink.git"
  },
  "bugs": {
    "url": "https://github.com/H4D3ZS/carelink/issues",
    "email": "support@carelink-qr.example.com"
  },
  "license": "MIT",
  "homepageUrl": "https://carelink-qr.example.com",
  "docs": "https://docs.carelink-qr.example.com",
  "apiUrl": "https://api.carelink-qr.example.com",
  "main": "docs/README.md",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "prepare": "husky install",
    "predeploy": "npm run build && npm run test:coverage"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "prettier": "^3.1.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "turbo": "^1.11.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "pnpm": ">=8.12.0"
  },
  "packageManager": "pnpm@8.12.0",
  "workflows": {
    "ci": ".github/workflows/ci.yml",
    "cd": ".github/workflows/cd.yml"
  },
  "quality": {
    "codeCoverage": "90%",
    "testCoverage": "85%",
    "documentationCoverage": "90%"
  },
  "deployment": {
    "platform": "GitHub Pages",
    "environment": "production",
    "monitoring": "continuous"
  }
}